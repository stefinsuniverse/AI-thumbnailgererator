    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "firebase-admin": "^13.4.0",
    "firebase-functions": "^6.5.2",
    "mongoose": "^9.1.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/node": "^20.0.0",
    "typescript": "^5.9.3"
